        .container { 
            max-width: 580px; 
            margin: 0 auto; 
            background: var(--card-bg); 
            padding: 28px 24px; 
            border-radius: 32px; 
            box-shadow: var(--shadow); 
            border: 1px solid rgba(255, 227, 232, 0.6);
        }
        
        .header { 
            text-align: center; 
            margin-bottom: 24px; 
            background: linear-gradient(135deg, #ffffff, var(--accent-light));
