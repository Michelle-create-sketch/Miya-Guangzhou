            --secondary: #4a5568; 
            --accent: #69b7ff; /* 慵懒晴空蓝 */
            --accent-light: #eef7ff;
            --bg: #f8f9fc; 
            --card-bg: #ffffff;
            --text-main: #2d3748;
            --text-muted: #718096;
            --shadow: 0 12px 40px rgba(255, 126, 157, 0.12);
        }
        
        * { box-sizing: border-box; transition: all 0.25s ease; }
        
        body { 
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif; 
            background: linear-gradient(180deg, var(--primary-light) 0%, var(--bg) 500px); 
            margin: 0; 
            padding: 20px 12px; 
            color: var(--text-main);
            line-height: 1.6;
