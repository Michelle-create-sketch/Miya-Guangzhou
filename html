            images: [
                "https://images.unsplash.com/photo-1512058564366-18510be2db19?w=400&h=400&fit=crop",
                "https://images.unsplash.com/photo-1582268611958-ebfd161ef9cf?w=400&h=400&fit=crop",
                "https://images.unsplash.com/photo-1600585154340-be6161a56a0c?w=400&h=400&fit=crop"
            ],
            path: [[113.268511, 23.125111], [113.265111, 23.123222], [113.263100, 23.116500]],
            districtName: "越秀区"
        }
    ];

    window.onload = function() {
        if(typeof AMap === 'undefined') return;
        const weather = new AMap.Weather();
        weather.getLive('440106', function(err, data) {
            const badge = document.getElementById('weather-info');
            if (!err) {
                let txt = `🌤️ 广州今日：${data.weather} ${data.temperature}℃`;
                if(data.weather.includes("雨") || data.weather.includes("雷")) {
                    is_rainy_day = true;
                    txt = `🌧️ 实时雨天！已智能切换室内避雨畅行游玩线`;
                }
                badge.innerHTML = txt;
            }
        });
        
        infoWindow = new AMap.InfoWindow({ offset: new AMap.Pixel(0, -32) });
    }

    function generateRoute() {
        document.getElementById('loading').style.display = 'inline-block';
        document.getElementById('btn-text').innerText = '正在智能编排路线与图鉴...';

        setTimeout(() => {
            const dVal = document.getElementById('district').value;
            const tVal = document.getElementById('taste').value;

            let matched = routeDatabase.find(r => r.tags.district === dVal && r.tags.taste === tVal);
            if(!matched) matched = routeDatabase.find(r => r.tags.taste === tVal);
            if(!matched) matched = routeDatabase.find(r => r.tags.district === dVal);
            if(!matched) matched = routeDatabase[Math.floor(Math.random() * routeDatabase.length)];

            currentMatchedRoute = matched;
            currentStationFlipState = {}; 

            document.getElementById('res-title').innerText = `🎉 已为您生成路线：${matched.title}`;
            document.getElementById('res-restaurant').innerText = matched.restaurant;
            
            let routeHtml = '';
            matched.steps.forEach((step, idx) => {
                routeHtml += `
                    <div class="route-step" onclick="focusOnStation(${idx})">
                        <div class="step-left">
                            <div class="step-title-row">
                                <span style="color:var(--primary); font-weight:bold;">第 ${idx+1} 站：${step}</span>
                                <span class="suggestion-tag" style="background:#fff0f3; color:var(--primary);">${matched.placeTypes[idx]}</span>
                            </div>
                            <div style="color:var(--text-muted); font-size:12.5px; margin-top:3px;">${matched.desc[idx]}</div>
                        </div>
                        <div class="distance-tag">📍 卡片看图</div>
                    </div>
                `;
            });
            document.getElementById('res-route').innerHTML = routeHtml;
            document.getElementById('result').style.display = 'block';

            initAndDrawAMapRoute(matched);

            document.getElementById('loading').style.display = 'none';
            document.getElementById('btn-text').innerText = '一键生成专属路线 ✨';
        }, 800);
    }

    function initAndDrawAMapRoute(routeData) {
        if (!map) {
            map = new AMap.Map('map-container', { resizeEnable: true, zoom: 13, center: routeData.path[0] });
            satelliteLayer = new AMap.TileLayer.Satellite();
            trafficLayer = new AMap.TileLayer.Traffic();
        } else {
            map.clearMap(); 
            if(walkingRoutePlugin) walkingRoutePlugin.clear(); 
        }

        if (!walkingRoutePlugin) {
            walkingRoutePlugin = new AMap.Walking({ map: map, panel: "panel" });
        }

        const pts = routeData.path;
        if(pts.length >= 2) drawSegment(0, pts);

        pts.forEach((lnglat, idx) => {
            const labelText = `第${idx+1}站:${routeData.placeTypes[idx]}${routeData.steps[idx]}`;
            const marker = new AMap.Marker({
                position: lnglat,
                label: {
                    content: `<div style="padding:4px 8px; border-radius:8px; background:#fff; border:1px solid var(--primary); font-size:11px; font-weight:bold; color:#2d3748; box-shadow:0 2px 6px rgba(0,0,0,0.1); white-space:nowrap;">${labelText}</div>`,
                    direction: 'bottom'
                },
                map: map
            });
            marker.on('click', () => { showStationPopup(idx, lnglat); });
        });
        map.setFitView();
    }

    function drawSegment(index, points) {
        if (index >= points.length - 1) return;
        walkingRoutePlugin.search(points[index], points[index + 1], function(status, result) {
            if (status === 'complete') drawSegment(index + 1, points);
        });
    }

    function focusOnStation(idx) {
        if(!currentMatchedRoute || !map) return;
        const lnglat = currentMatchedRoute.path[idx];
        map.setZoomAndCenter(16, lnglat);
        showStationPopup(idx, lnglat);
    }

    function showStationPopup(idx, lnglat) {
        const route = currentMatchedRoute;
        const isTextMode = currentStationFlipState[idx] || false; 
        let contentHtml = '';
        if (!isTextMode) {
            contentHtml = `
                <div class="info-card-box">
                    <img class="info-card-img" src="${route.images[idx]}" />
                    <div class="info-card-body">
                        <div>
                            <strong style="color:var(--primary); font-size:13.5px;">${route.placeTypes[idx]} ${route.steps[idx]}</strong>
                        </div>
                        <div><button class="flip-toggle-btn" onclick="executeCardFlip(${idx}, '${lnglat.join(',')}')">🔄 反转查看简介</button></div>
                    </div>
                </div>
            `;
        } else {
            contentHtml = `
                <div class="info-card-text-only">
                    <div>
                        <span style="background:var(--primary-light); color:var(--primary); padding:2px 6px; border-radius:6px; font-size:11px; font-weight:bold;">${route.placeTypes[idx]}</span>
                        <h4 style="margin:8px 0 4px 0; color:var(--primary); font-size:15px; font-weight:800;">${route.steps[idx]}</h4>
                        <p style="margin:6px 0; color:#4a5568; font-size:12.5px;">🐾 <strong>探店手记：</strong>${route.desc[idx]}</p>
                    </div>
                    <div><button class="flip-toggle-btn" style="background:var(--accent);" onclick="executeCardFlip(${idx}, '${lnglat.join(',')}')">🔄 反转查看实拍图片</button></div>
                </div>
            `;
        }
        infoWindow.setContent(contentHtml);
        infoWindow.open(map, lnglat);
    }

    function executeCardFlip(idx, lnglatString) {
        const lnglat = lnglatString.split(',').map(Number);
        currentStationFlipState[idx] = !currentStationFlipState[idx];
        showStationPopup(idx, lnglat);
    }

    function toggleLayers() {
        if(!map) return;
        if(document.getElementById('satellite-layer').checked) map.add(satelliteLayer); else map.remove(satelliteLayer);
        if(document.getElementById('traffic-layer').checked) map.add(trafficLayer); else map.remove(trafficLayer);
    }

    function openAMapApp() {
        if(!currentMatchedRoute) return;
        const route = currentMatchedRoute;
        const endPt = route.path[route.path.length - 1];
        const endName = route.steps[route.steps.length - 1];
        window.open(`https://uri.amap.com/navigation?to=${endPt[0]},${endPt[1]},${endName}&mode=walk&src=miya_gz`, '_blank');
    }

    // 手账本生成及本地存储联动核心逻辑
    function generateTravelJournal() {
        if(!currentMatchedRoute) return;
        const section = document.getElementById('journal-section');
        const autoText = document.getElementById('journal-auto-text');
        
        section.style.display = 'block';
        autoText.innerHTML = `
            📖 今天在 <strong>${currentMatchedRoute.districtName}</strong> 畅玩了一整天！<br>
            从【${currentMatchedRoute.steps[0]}】快乐出发，完美打卡了多处景点与美食！路线打分：⭐⭐⭐⭐⭐
        `;
        
        // 从本地存储读取历史照片和手写文字
        loadJournalFromStorage();
        section.scrollIntoView({ behavior: 'smooth' });
    }

    // 监听用户上传并转换成 Base64 永久本地储存
    function handlePhotoUpload(input) {
        if (!input.files || !input.files[0]) return;
        
        Array.from(input.files).forEach(file => {
            const reader = new FileReader();
            reader.onload = function(e) {
                const base64Img = e.target.result;
                // 获取已经存的照片
                let savedPhotos = JSON.parse(localStorage.getItem('miya_journal_photos') || '[]');
                savedPhotos.push(base64Img);
                localStorage.setItem('miya_journal_photos', JSON.stringify(savedPhotos));
                
                // 刷新相册视图
                renderPhotos(savedPhotos);
            }
            reader.readAsDataURL(file);
        });
    }

    function renderPhotos(photoArray) {
        const grid = document.getElementById('journal-photos');
        grid.innerHTML = '';
        photoArray.forEach(imgData => {
            const div = document.createElement('div');
            div.className = 'journal-photo-item';
            div.innerHTML = `<img src="${imgData}" alt="旅途精彩瞬间">`;
            grid.appendChild(div);
        });
    }

    // 保存文本手写笔记到本地
    function saveJournalToStorage() {
        const noteText = document.getElementById('journal-user-note').value;
        localStorage.setItem('miya_journal_note', noteText);
    }

    // 页面加载或切换时回填已保存的数据
    function loadJournalFromStorage() {
        const note = localStorage.getItem('miya_journal_note') || '';
        document.getElementById('journal-user-note').value = note;
        
        const savedPhotos = JSON.parse(localStorage.getItem('miya_journal_photos') || '[]');
        renderPhotos(savedPhotos);
    }

    // 清空手账
    function clearSavedJournal() {
        if(confirm("确定要清空你写的手账和相册照片吗？")) {
            localStorage.removeItem('miya_journal_note');
            localStorage.removeItem('miya_journal_photos');
            document.getElementById('journal-user-note').value = '';
            document.getElementById('journal-photos').innerHTML = '';
        }
    }
</script>

