                <option value="stalls">🔥 深夜镬气大排档/生滚粥</option>
            </select>
        </div>
        <div class="form-group">
            <label for="budget">💵 人均预算</label>
            <select id="budget">
                <option value="50">50元以下 (学生党最爱)</option>
                <option value="50-100">50-100元 (平价大碗)</option>
                <option value="200-300">200-300元 (老饕私藏)</option>
                <option value="300">300元以上 (高端品质)</option>
            </select>
        </div>
        <div class="form-group">
            <label for="time">🕒 出行场景/时段</label>
            <select id="time">
                <option value="day">晴空漫步 (赏日光建筑)</option>
                <option value="night">夜幕观光 (吹珠江微风)</option>
                <option value="date">情侣约会 (小调极其浪漫)</option>
