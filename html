        .journal-photo-item:nth-child(even) { transform: rotate(-1.5deg); }
        .journal-photo-item img {
            width: 100%;
            height: 120px;
            object-fit: cover;
            border-radius: 4px;
        }
        .journal-textarea {
            width: 100%;
            height: 100px;
            background: transparent;
            border: none;
            font-family: inherit;
            font-size: 14px;
            line-height: 26px;
            color: #4a3728;
            resize: none;
            outline: none;
        }
        
        .secondary-btn {
            width: 100%;
            padding: 14px;
            background: linear-gradient(135deg, var(--accent), #4dafff);
            color: white;
            border: none;
            border-radius: 16px;
            font-size: 15px;
            font-weight: bold;
            cursor: pointer;
            margin-top: 12px;
            box-shadow: 0 4px 15px rgba(105, 183, 255, 0.3);
        }
        .secondary-btn:hover { transform: translateY(-1px); box-shadow: 0 6px 18px rgba(105, 183, 255, 0.4); }

        /* 高德地图大头针气泡样式自适应 */
        .amap-info-content {
            border-radius: 24px !important;
            border: 2.5px solid var(--primary) !important;
            box-shadow: 0 12px 32px rgba(255,126,157,0.25) !important;
            padding: 0 !important;
