        }
        .info-card-box { width: 230px; font-family: -apple-system, sans-serif; background: #fff; min-height: 270px; display: flex; flex-direction: column;}
        .info-card-img { width: 230px; height: 160px; object-fit: cover; display: block; border-bottom: 1px solid #ffe3e8; }
        .info-card-body { padding: 14px; font-size: 13px; flex: 1; display: flex; flex-direction: column; justify-content: space-between;}
        
        /* 纯文本深度体验模式 */
        .info-card-text-only {
            width: 230px;
            padding: 16px;
            font-size: 13px;
            background: #fffbfd;
            min-height: 270px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

