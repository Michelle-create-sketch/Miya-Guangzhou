            background-position: right 16px center;
            background-size: 12px;
        }
        select:focus { 
            border-color: var(--primary); 
            background-color: #ffffff;
            box-shadow: 0 0 0 4px rgba(255, 126, 157, 0.12);
        }
        
        button.primary-btn { 
            width: 100%; 
            padding: 16px; 
            background: linear-gradient(135deg, var(--primary), #ff527b); 
            color: white; 
            border: none; 
            border-radius: 18px; 
            font-size: 16px; 
            cursor: pointer; 
            font-weight: 800; 
            box-shadow: 0 8px 24px rgba(255, 126, 157, 0.35); 
            margin-bottom: 24px; 
            position: relative; 
            letter-spacing: 1px;
        }
        button.primary-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 28px rgba(255, 126, 157, 0.45); 
        }
        button.primary-btn:active { transform: translateY(1px); }
        
        .loading-spin { 
            display: none; 
            width: 20px; 
            height: 20px; 
            border: 3px solid rgba(255,255,255,0.3); 
            border-top: 3px solid white; 
            border-radius: 50%; 
            animation: spin 0.8s linear infinite; 
            position: absolute; 
            left: 20px; 
            top: calc(50% - 10px); 
        }
        @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }

        .result-card { display: none; animation: popIn 0.45s cubic-bezier(0.165, 0.84, 0.44, 1) both; }
        @keyframes popIn { from { opacity: 0; transform: translateY(15px); } to { opacity: 1; transform: translateY(0); } }
        
        .res-box { 
            background: linear-gradient(to bottom, #ffffff, #fffdfa); 
            border: 1px solid #ffe3e8; 
            padding: 20px; 
            border-radius: 24px; 
            margin-bottom: 20px; 
            box-shadow: 0 4px 20px rgba(0,0,0,0.01);
        }
        
        .route-step { 
            display: flex; 
            align-items: center; 
            justify-content: space-between; 
            margin: 12px 0; 
            padding: 16px; 
            background: #ffffff; 
            border: 1.5px solid #edf2f7; 
            border-radius: 16px; 
            cursor: pointer; 
            box-shadow: 0 2px 6px rgba(0,0,0,0.01);
        }
        .route-step:hover { 
            border-color: var(--primary); 
            background: #fffbfd; 
            transform: scale(1.015);
        }
        .step-left { display: flex; flex-direction: column; gap: 4px; font-size: 14px; flex: 1; padding-right: 12px; }
        .step-title-row { display: flex; align-items: center; gap: 8px; font-weight: bold;}
        
        .distance-tag { 
            font-size: 12px; 
            background: var(--accent-light); 
            color: #0070c9; 
            padding: 3px 8px; 
            border-radius: 8px; 
            font-weight: bold; 
            display: inline-flex;
            align-items: center;
            gap: 4px;
        }
        .suggestion-tag {
            font-size: 11.5px;
            background: #f0fff4;
            color: #2f855a;
            padding: 3px 8px;
            border-radius: 8px;
            font-weight: 700;
        }
        
        .map-wrapper { 
            position: relative; 
            border-radius: 24px; 
            border: 4px solid #ffe3e8; 
            overflow: hidden; 
            margin-bottom: 20px;
            box-shadow: var(--shadow);
        }
        #map-container { width: 100%; height: 380px; }
        
        .layer-ctrl { 
            position: absolute; 
            top: 12px; 
            right: 12px; 
            background: rgba(255, 255, 255, 0.95); 
            padding: 8px 12px; 
            border-radius: 16px; 
            z-index: 999; 
            display: flex; 
            flex-direction: column; 
            gap: 6px; 
            font-size: 12px; 
            border: 1px solid #ffe3e8;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        }
        .layer-ctrl label { margin: 0; font-weight: 600; cursor: pointer; }
        
        /* 深度优化：超拟真手账日记本样式 */
